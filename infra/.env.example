# ─────────────────────────────────────────────────────────────────────
# Astra environment configuration. Copy to `.env` at the repo root and
# fill in the values you actually have. Nothing here is secret-by-default.
# ─────────────────────────────────────────────────────────────────────

# --- Database ---
DATABASE_URL=postgresql+asyncpg://astra:astra@localhost:5432/astra

# --- Redis (used by workers + cache) ---
REDIS_URL=redis://localhost:6379/0

# --- Groq (fast cloud LLM — preferred for demo) ---
# Get a free API key at https://console.groq.com/keys (no credit card)
GROQ_API_KEY=

# --- Ollama (local LLM fallback) ---
OLLAMA_HOST=http://localhost:11434
ASTRA_LLM_MODEL=ollama/llama3.1:8b-instruct-q4_K_M
ASTRA_LLM_MODEL_CREATIVE=ollama/llama3.1:8b-instruct-q4_K_M
ASTRA_LLM_TEMPERATURE_DEFAULT=0.2
ASTRA_LLM_TEMPERATURE_CREATIVE=0.7

# --- GitHub API (used by Vault, Bridge-to-Build scaffolder, Trust Score) ---
# Personal access token with `repo` + `read:user` scopes.
GITHUB_TOKEN=

# --- SendGrid (digest delivery) ---
# Leave empty to skip email sending in dev.
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=astra@example.com

# --- FAISS index location ---
FAISS_INDEX_PATH=./data/faiss/opportunities.index

# --- API server ---
API_HOST=0.0.0.0
API_PORT=8000
API_CORS_ORIGINS=http://localhost:3000

# --- Frontend ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
